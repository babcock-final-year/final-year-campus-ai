# Backend environment variables for Campus AI (Flask)
#
# Copy this file to `.env` in this directory (`apps/backend/.env`) and fill in values.
# Notes:
# - Do NOT commit `.env` with real secrets.
# - Values here are examples/placeholders.
# - If a variable is optional, the app will fall back to a default (noted below).

# ==============================================================================
# Core app secrets (HIGHLY RECOMMENDED to set, even in dev)
# ==============================================================================

# Flask secret used for signing links/tokens (email confirm/reset/change-email).
# If not set, the backend generates a random value on each startup, which will
# invalidate previously issued confirmation/reset links after a restart.
SECRET_KEY=change-me-generate-a-long-random-string

# Secret used to sign JWT access/refresh tokens (flask_jwt_extended).
# If not set, the backend generates a random value on each startup, which will
# invalidate all existing JWTs after a restart.
JWT_SECRET_KEY=change-me-generate-a-long-random-string

# How to generate good values:
#   openssl rand -hex 32
# or any cryptographically-random 64+ char string.

# ==============================================================================
# Base URL (used to generate links in emails)
# ==============================================================================

# Base URL of your backend (where the backend is reachable by users).
# Used when generating email links (confirm/reset). Default if unset:
#   http://localhost:5000
BASE_URL=http://localhost:5000

# ==============================================================================
# Database
# ==============================================================================

# Development database URL. Default if unset:
#   sqlite:///apps/backend/data-dev.db (local sqlite file)
# Use this if you want to point dev to Postgres/MySQL/etc.
# Examples:
#   DEV_DATABASE_URL=sqlite:////absolute/path/to/data-dev.db
#   DEV_DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/campus_ai
DEV_DATABASE_URL=

# Test database URL. Default if unset:
#   sqlite:///:memory:
TEST_DATABASE_URL=

# Production database URL. REQUIRED in production configuration.
# Example:
#   DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname
DATABASE_URL=

# ==============================================================================
# Email (SMTP) - REQUIRED if you want register/confirm/reset emails to work
# ==============================================================================

# The backend config uses Gmail SMTP by default:
#   server: smtp.googlemail.com
#   port: 587
#   TLS: true
#
# If you use Gmail:
# - MAIL_USERNAME is your Gmail address
# - MAIL_PASSWORD must be a Google "App Password" (not your normal password)
#   Create it in: Google Account -> Security -> App passwords (requires 2FA)
MAIL_USERNAME=
MAIL_PASSWORD=
# Default sender email shown to recipients. Often the same as MAIL_USERNAME.
# You can include a display name, e.g.:
#   MAIL_DEFAULT_SENDER="Unipal <your-email@gmail.com>"
MAIL_DEFAULT_SENDER=

# ==============================================================================
# Token expiry settings (optional)
# ==============================================================================

# Seconds before email confirmation link expires. Default: 3600 (1 hour)
CONFIRM_TOKEN_EXPIRES=3600
# Seconds before password reset link expires. Default: 3600 (1 hour)
RESET_TOKEN_EXPIRES=3600
# Seconds before change-email confirmation link expires. Default: 3600 (1 hour)
EMAIL_CHANGE_TOKEN_EXPIRES=3600

# ==============================================================================
# Google OAuth (only required if you use /api/v1/auth/google)
# ==============================================================================

# Google OAuth Client ID used to verify Google ID tokens.
# Get it from: Google Cloud Console -> APIs & Services -> Credentials -> OAuth client
GOOGLE_CLIENT_ID=

# ==============================================================================
# RAG / AI configuration (only required if you use the RAG features)
# ==============================================================================

# Gemini API key (Google AI Studio / Google Cloud)
GEMINI_API_KEY=

# Optional model names (defaults shown). Only change if you know what you’re doing.
# Default: text-embedding-004
GEMINI_EMBEDDINGS_MODEL=text-embedding-004
# Default: gemini-3-pro
GEMINI_LLM_MODEL=gemini-3-pro

# Hugging Face embeddings path (only if used by your RAG pipeline)
# HF_EMBEDDINGS_MODEL should be a model id from Hugging Face Hub, e.g.:
#   sentence-transformers/all-MiniLM-L6-v2
HF_EMBEDDINGS_MODEL=
# If you use private/gated models, create a token at:
#   Hugging Face -> Settings -> Access Tokens
HF_ACCESS_TOKEN=

# Groq (only if used by your LLM path)
# Get key from: Groq Console / API Keys page
GROQ_API_KEY=
# Optional model name (depends on your Groq setup)
GROQ_LLM_MODEL=

# ==============================================================================
# Local data paths for ingestion/vector store (optional)
# ==============================================================================

# Relative to apps/backend/ by default.
# Default: data
DATA_DIRECTORY=data
# Default: chroma_db
CHROMA_PATH=chroma_db
# Default: prompt.txt
PROMPT_PATH=prompt.txt

# Retrieval top-k. Default: 5
TOP_K=5
